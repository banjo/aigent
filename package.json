{
    "name": "@banjoanton/aigent",
    "type": "module",
    "version": "0.0.1",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "description": "",
    "author": "Anton Ödman <anton.odman@gmail.com>",
    "license": "MIT",
    "homepage": "https://github.com/banjo/aigent#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/banjo/aigent.git"
    },
    "bugs": "https://github.com/banjo/aigent/issues",
    "keywords": [],
    "sideEffects": false,
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": "dist/bin.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.cjs",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "preview": "node dist/bin.js",
        "dev": "tsdown --watch",
        "lint": "eslint .",
        "prepublishOnly": "nr build",
        "release": "bumpp && npm publish",
        "start": "tsx src/bin.ts",
        "start:fixture": "tsx src/bin.ts run --root local/aigent --repositoryRoot local/target-repo --model crof/deepseek-v4-pro",
        "test": "vitest --watch=false",
        "test:dev": "vitest",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "change:add": "changeset add",
        "change:version": "changeset version",
        "change:publish": "changeset publish"
    },
    "dependencies": {
        "@clack/prompts": "^1.5.1",
        "citty": "^0.2.2",
        "consola": "^3.4.2",
        "execa": "^9.6.1",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@antfu/ni": "^30.1.0",
        "@banjoanton/eslint-config": "^0.2.20",
        "@banjoanton/prettier-config": "^0.1.11",
        "@banjoanton/typescript-config": "^0.0.2",
        "@banjoanton/utils": "^1.1.16",
        "@changesets/cli": "^2.31.0",
        "@total-typescript/tsconfig": "^1.0.4",
        "@types/node": "^25.9.3",
        "eslint": "^10.5.0",
        "pnpm": "^11.6.0",
        "prettier": "^3.8.4",
        "tsdown": "^0.22.2",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    },
    "prettier": "@banjoanton/prettier-config"
}
